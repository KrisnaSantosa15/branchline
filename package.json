    "test:distribution": "node scripts/test-distribution.mjs",
    "test:codex-plugin": "node scripts/test-codex-plugin.mjs",
    "test:claude-plugin": "node scripts/test-claude-plugin.mjs",
    "package:check": "npm pack --dry-run"
  },
  "dependencies": {
    "@types/better-sqlite3": "latest",
    "better-sqlite3": "latest",
    "clsx": "latest",
    "drizzle-orm": "latest",
