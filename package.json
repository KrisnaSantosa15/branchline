{
  "name": "@krisnasantosa15/branchline",
  "version": "0.2.0",
  "private": false,
  "description": "Evidence-led, read-only Git release rehearsal for humans and coding agents.",
  "license": "MIT",
  "bin": {
    "branchline": "./bin/branchline.mjs"
  },
  "files": [
    "bin",
    ".claude-plugin/marketplace.json",
    "integrations",
    "plugins",
    "scripts/branchline.ts",
    "scripts/council.ts",
    "scripts/check.ts",
    "scripts/validate-council-report.ts",
    "src/lib/analysis.ts",
    "src/lib/artifacts.ts",
    "src/lib/council.ts",
    "src/lib/policy.ts",
    "src/lib/domain.ts",
    "src/lib/repository.ts",
    "tsconfig.json",
    "README.md",
    "DISTRIBUTION.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "db:push": "drizzle-kit push",
    "fixture:reset": "tsx scripts/reset-fixture.ts",
