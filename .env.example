# Optional: enables browser-side advisor proposals through any Chat Completions-compatible endpoint.
# Leave all three unset to use deterministic proposals only. The $branchline Codex skill needs no separate key.
BRANCHLINE_ADVISOR_ENDPOINT=
BRANCHLINE_ADVISOR_API_KEY=
BRANCHLINE_ADVISOR_MODEL=

# Branchline only accepts repositories under this path. Update it for local use.
BRANCHLINE_REPO_ROOT=C:\\path\\to\\approved-repositories
